# ======================================
# RailVision AI — Environment Variables
# ======================================

# ── Frontend (Next.js) ──────────────────
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_MAP_CENTER_LAT=19.076
NEXT_PUBLIC_MAP_CENTER_LNG=72.8479
NEXT_PUBLIC_MAP_DEFAULT_ZOOM=12

# Backend URL for Next.js API proxy routes
BACKEND_URL=http://localhost:8000

# ── Backend (FastAPI) ───────────────────
# Place these in backend/app/.env

# MongoDB
MONGODB_URI=mongodb://localhost:27017
DB_NAME=railvision_db

# Authentication
JWT_SECRET=railvision-hackathon-secret-key-2024-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# File uploads
UPLOAD_DIR=uploads

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,*

# Fallback mode — set to true to run without MongoDB
FALLBACK_MODE=true

# ── Demo Credentials ────────────────────
# Admin:  admin@railvision.ai / admin123
# User:   demo@railvision.ai  / demo123
